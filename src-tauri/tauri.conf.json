{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI 中转额度消耗检测",
  "version": "0.1.4",
  "identifier": "com.wnluo.ai-transfer-quota-auditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI 中转额度消耗检测",
        "width": 1280,
        "height": 860,
        "minWidth": 420,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
